# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek API (AI text generation)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Xiaomi MiMo API (AI text generation, multimodal)
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# SiliconFlow (Embeddings - free tier)
SILICONFLOW_API_KEY=your-siliconflow-api-key

# Volcengine (豆包语音转写 2.0)
VOLC_APP_ID=your-volcengine-app-id
VOLC_API_KEY=your-volcengine-api-key

# Site URL (for auth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
